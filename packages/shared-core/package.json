{
  "name": "@telli/shared-core",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "exports": {
    "./*": "./src/*.ts"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "types": "tsc --noEmit",
    "check-types": "tsc --noEmit",
    "lint": "eslint \"**/*.ts*\" --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@sentry/core": "10.43.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@telli/typescript-config": "workspace:*",
    "@types/node": "24.11.0",
    "@vitest/coverage-v8": "4.1.0",
    "eslint": "9.39.4",
    "eslint-config-turbo": "2.8.17",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0",
    "vitest": "4.1.0"
  }
}
